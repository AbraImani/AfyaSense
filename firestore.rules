rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Sécurité par défaut : Tout refuser
    match /{document=**} {
      allow read, write: if false;
    }

    // Fonctions helpers
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128; }

    // Règles pour les cas de santé
    match /healthCases/{caseId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(caseId);
      allow update, delete: if false; // Immuabilité par défaut pour la démo
    }

    // Règles pour les alertes
    match /epidemicAlerts/{alertId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}
